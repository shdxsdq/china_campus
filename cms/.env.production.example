HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://cms.example.cn
IS_PROXIED=true
ADMIN_PATH=/admin
APP_KEYS="replace-with-long-random-value-1,replace-with-long-random-value-2"
API_TOKEN_SALT=replace-with-long-random-value
ADMIN_JWT_SECRET=replace-with-long-random-value
TRANSFER_TOKEN_SALT=replace-with-long-random-value
JWT_SECRET=replace-with-long-random-value
ENCRYPTION_KEY=replace-with-long-random-value

# Production should use a managed relational database in mainland China.
DATABASE_CLIENT=mysql
DATABASE_HOST=rm-xxxx.rds.aliyuncs.com
DATABASE_PORT=3306
DATABASE_NAME=china_campus
DATABASE_USERNAME=china_campus
DATABASE_PASSWORD=replace-with-strong-password
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000

SEED_DEMO_DATA=false

# Browser-facing frontend domains.
FRONTEND_URL=https://www.example.cn,https://example.cn
CORS_ORIGINS=https://www.example.cn,https://example.cn

# Restrict the admin panel to fixed office or VPN IPs when possible.
ADMIN_IP_ALLOWLIST=

# Add CDN or OSS/COS domains here if media is served outside the CMS origin.
CSP_CONNECT_SOURCES=https://www.example.cn,https://example.cn
CSP_IMG_SOURCES=https://www.example.cn,https://example.cn

ENABLE_HTTPS_REDIRECT=true
