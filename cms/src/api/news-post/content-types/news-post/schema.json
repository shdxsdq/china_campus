{
  "kind": "collectionType",
  "collectionName": "news_posts",
  "info": {
    "singularName": "news-post",
    "pluralName": "news-posts",
    "displayName": "News Post",
    "description": "Campus news entries"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishedDate": {
      "type": "date",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "json"
    },
    "highlights": {
      "type": "json"
    },
    "coverImageUrl": {
      "type": "string"
    }
  }
}
