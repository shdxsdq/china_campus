{
  "kind": "collectionType",
  "collectionName": "notice_posts",
  "info": {
    "singularName": "notice-post",
    "pluralName": "notice-posts",
    "displayName": "Notice Post",
    "description": "Campus notice entries"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishedDate": {
      "type": "date",
      "required": true
    },
    "author": {
      "type": "string",
      "default": "学校办公室"
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "blocks"
    },
    "highlights": {
      "type": "json",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "coverImageUrl": {
      "type": "string",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
