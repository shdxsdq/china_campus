# Browser-safe values only
NEXT_PUBLIC_SITE_URL=https://www.example.cn

# Server-only CMS access
# Use a private IP, private DNS, or localhost here when the frontend can reach
# Strapi over an internal network.
STRAPI_URL=http://127.0.0.1:1337

# Public CMS origin used for media URLs rendered into HTML.
STRAPI_PUBLIC_URL=https://cms.example.cn

# Read-only Strapi API token.
STRAPI_API_TOKEN=replace-with-a-read-only-token

# Optional extra CSP sources for CDN or object storage domains.
SITE_CSP_CONNECT_SOURCES=https://cms.example.cn
SITE_CSP_IMG_SOURCES=https://cms.example.cn
SITE_CSP_MEDIA_SOURCES=https://cms.example.cn
