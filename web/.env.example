# Browser-safe values only
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only CMS access
# STRAPI_URL may point to an internal address that only the Next.js server can reach.
STRAPI_URL=http://127.0.0.1:1337
# STRAPI_PUBLIC_URL should be reachable by end users' browsers in production.
STRAPI_PUBLIC_URL=http://127.0.0.1:1337
STRAPI_API_TOKEN=replace-with-a-read-only-token

# Optional extra CSP sources for CDN or split-domain deployments.
SITE_CSP_CONNECT_SOURCES=
SITE_CSP_IMG_SOURCES=
SITE_CSP_MEDIA_SOURCES=
